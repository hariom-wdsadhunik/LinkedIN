# LinkedIn Manager Configuration
# Copy this file to .env and fill in your credentials

# LinkedIn Credentials
LINKEDIN_EMAIL=your_email@example.com
LINKEDIN_PASSWORD=your_password_here

# Optional: Multi-Factor Authentication Secret (for TOTP)
# Get this from your authenticator app's backup codes
LINKEDIN_MFA_SECRET=

# Account Settings
# Options: new (<3mo), established (3-12mo), premium (>1yr)
ACCOUNT_TIER=established

# Rate Limits (override defaults if needed)
MAX_CONNECTIONS_PER_DAY=20
MAX_POSTS_PER_DAY=2
MAX_PROFILE_VIEWS_PER_DAY=60
MAX_MESSAGES_PER_DAY=15

# Browser Settings
# true = headless (no GUI, production)
# false = visible browser (debugging)
BROWSER_HEADLESS=false

# Timezone for scheduling
TIMEZONE=Asia/Kolkata  # Change to your timezone (e.g., Asia/Kolkata for India)

# Logging Level
# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Auto-confirm actions (skip user prompts)
# true = automate without confirmation
# false = ask before critical actions
AUTO_CONFIRM=false
